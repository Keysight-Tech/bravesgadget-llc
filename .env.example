# Environment Configuration for BravesGadget LLC
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git

# Domain Configuration
DOMAIN=keysight-tech.github.io/bravesgadget-llc
ADMIN_SUBDOMAIN=admin.keysight-tech.github.io/bravesgadget-llc

# GitHub Pages
GITHUB_REPO=Keysight-Tech/bravesgadget-llc
GITHUB_PAGES_URL=https://keysight-tech.github.io/bravesgadget-llc/

# IONOS Account (for DNS management reference only)
IONOS_EMAIL=your-email@example.com
# NOTE: Never store passwords in plain text
# Use a password manager like 1Password, LastPass, or Bitwarden

# Supabase Configuration (if using)
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# Admin Panel
ADMIN_URL=https://admin.keysight-tech.github.io/bravesgadget-llc/admin.html

# API Keys (if any)
# STRIPE_PUBLIC_KEY=
# PAYPAL_CLIENT_ID=
